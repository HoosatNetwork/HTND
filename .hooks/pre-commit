#!/bin/sh

# Auto-format Go files with gofmt -s before commit (no Python required)

# Get only staged .go files that are added/modified
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.go$')

if [ -z "$STAGED_GO_FILES" ]; then
    exit 0
fi

echo "🔧 Running gofmt -s on staged Go files..."

for file in $STAGED_GO_FILES; do
    # Format with simplify flag and write changes
    gofmt -s -w "$file"
    
    # Re-stage the formatted file so the changes are included in the commit
    git add "$file"
done

echo "✅ gofmt -s applied successfully"
